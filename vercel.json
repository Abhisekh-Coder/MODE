{
  "version": 2,
  "public": true,
  "buildCommand": "cd frontend && npm install && npx vite build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 300,
      "includeFiles": "src/**/*.py,prompts/**/*.txt,data/**/*.csv,api/**/*.py,api/requirements.txt"
    }
  }
}
